# =============================================================================
# Outpost Bot — Environment Variables
# =============================================================================
# Copy this file to `.env` (for VPS / Hostinger / Contabo deploys) and fill in
# real values. On Replit, secrets are managed via the Secrets pane and you do
# NOT need a .env file — just keep the values in Secrets.
# =============================================================================

# --- Discord (required) ---
# Get these from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-application-client-id
DISCORD_GUILD_ID=your-discord-server-id

# --- Database (required) ---
# Standard Postgres connection string. Works with any Postgres provider:
# Replit DB, Neon, Supabase, self-hosted on Contabo, Hostinger PG, etc.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://user:password@localhost:5432/outpost

# --- Web session (required) ---
# Long random string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-long-random-string

# --- Server port (optional) ---
# The HTTP port the API server listens on. Defaults to 3000.
# On Replit this is set automatically by the artifact system.
PORT=3000

# --- Production mode (recommended on VPS) ---
# Set to "production" to enable secure cookies and disable dev-only features.
NODE_ENV=production

# --- Single-process dashboard hosting (VPS only) ---
# Set this on a VPS to make the API server also serve the built dashboard.
# Build the dashboard first with `pnpm --filter @workspace/dashboard run build`,
# then point this at the resulting dist directory. Leave UNSET on Replit.
# DASHBOARD_DIST_PATH=/var/www/outpost/artifacts/dashboard/dist/public

# --- Logging (optional) ---
# Pino log level: trace, debug, info, warn, error, fatal. Defaults to "info".
# LOG_LEVEL=info

# --- OSINT Integration (required for verification and checks) ---
# The URL where the redditOSITN Python backend is running.
REDDIT_OSINT_URL="https://harrry953489-redditapi.hf.space"
