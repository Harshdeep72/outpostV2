{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && (fuser -k 8080/tcp 2>/dev/null; sleep 1; true) && pnpm run start",
    "build": "node ./build.mjs",
    "start": "NODE_ENV=production node --enable-source-maps ./dist/index.mjs",
    "start:prod": "NODE_ENV=production node ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "@types/express-session": "^1.19.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "discord.js": "^14.26.3",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-session": "^1.19.0",
    "google-auth-library": "^10.6.2",
    "googleapis": "^172.0.0",
    "pino": "^9",
    "pino-http": "^10",
    "undici": "^7.25.0"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
